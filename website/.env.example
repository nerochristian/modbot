# Optional: base URL where the bot dashboard API is reachable.
# If omitted, frontend uses same-origin (/api).
# Example for split deployment: https://your-bot-service.up.railway.app
VITE_API_BASE_URL=

# Optional: base URL for auth routes (/auth/login, /auth/callback).
# Defaults to VITE_API_BASE_URL when omitted.
VITE_AUTH_BASE_URL=
